---
import MainLayout from '../presentation/layouts/MainLayout.astro';
import { CustomersPageComponent } from '../presentation/features/customers/customers-page.component';
import { loadCustomersInitialData } from '../presentation/shared/ssr-page-data';
import type { AppLocale } from '../presentation/shared/services/locale.service';

const initialLocale: AppLocale = 'en';
const initialData = await loadCustomersInitialData(Astro, initialLocale);
---

<MainLayout title="BillFlow - Customer Management" lang={initialLocale}>
  <div class="relative isolate min-h-[100dvh] overflow-hidden bg-background text-on-background">
    <div class="relative z-10">
      <CustomersPageComponent client:load initialLocale={initialLocale} initialData={initialData} />
    </div>
  </div>
</MainLayout>
