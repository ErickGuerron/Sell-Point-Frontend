---
import MainLayout from '../presentation/layouts/MainLayout.astro';
import { CustomersPageComponent } from '../presentation/features/customers/customers-page.component';
import { loadCustomersInitialData } from '../presentation/shared/ssr-page-data';

const initialData = await loadCustomersInitialData(Astro);
---

<MainLayout title="BillFlow - Customer Management" lang="en">
  <div class="relative isolate min-h-[100dvh] overflow-hidden bg-background text-on-background">
    <div class="relative z-10">
      <CustomersPageComponent client:load initialData={initialData} />
    </div>
  </div>
</MainLayout>
