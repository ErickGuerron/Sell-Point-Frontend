---
import MainLayout from '../presentation/layouts/MainLayout.astro';
import { AuditPageComponent } from '../presentation/features/audit/audit-page.component';
import { loadAuditInitialData } from '../presentation/shared/ssr-page-data';
import type { AppLocale } from '../presentation/shared/services/locale.service';

const initialLocale: AppLocale = 'en';
const initialData = await loadAuditInitialData(Astro, initialLocale);
---

<MainLayout title="BillFlow - Audit Log" lang={initialLocale}>
  <div class="relative isolate min-h-[100dvh] overflow-hidden bg-background text-on-background">
    <div class="relative z-10">
      <AuditPageComponent client:load initialLocale={initialLocale} initialData={initialData} />
    </div>
  </div>
</MainLayout>
