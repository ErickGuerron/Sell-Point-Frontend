---
import MainLayout from '../presentation/layouts/MainLayout.astro';
import { ProductsPageComponent } from '../presentation/features/products/products-page.component';
import { loadProductsInitialData } from '../presentation/shared/ssr-page-data';
import type { AppLocale } from '../presentation/shared/services/locale.service';

const initialLocale: AppLocale = 'en';
const initialData = await loadProductsInitialData(Astro, initialLocale);
---

<MainLayout title="BillFlow - Product Management" lang={initialLocale}>
  <div class="relative isolate min-h-[100dvh] overflow-hidden bg-background text-on-background">
    <div class="relative z-10">
      <ProductsPageComponent client:load initialLocale={initialLocale} initialData={initialData} />
    </div>
  </div>
</MainLayout>
