---
import MainLayout from '../presentation/layouts/MainLayout.astro';
import { AuthParticlesBackgroundComponent } from '../presentation/features/auth/auth-particles-background.component';
import { ResetPasswordPageComponent } from '../presentation/features/auth/reset-password-page.component';
import { resolveApiBaseUrl } from '../presentation/shared/services/api-base';

const token = Astro.url.searchParams.get('token');
const isPlausibleToken = typeof token === 'string' && /^[a-f0-9]{64}$/i.test(token.trim());

if (!isPlausibleToken) {
  return Astro.redirect('/auth');
}

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

const apiBaseUrl = resolveApiBaseUrl();

let tokenValidation: { valid: boolean; reason?: string } | null = null;

try {
  const validationResponse = await fetch(`${apiBaseUrl}/auth/reset-password/validate?token=${encodeURIComponent(token!)}`, {
    headers: { accept: 'application/json' },
    cache: 'no-store',
  });

  if (!validationResponse.ok) {
    return Astro.redirect('/auth');
  }

  tokenValidation = await validationResponse.json();
} catch {
  return Astro.redirect('/auth');
}

if (!tokenValidation?.valid) {
  return Astro.redirect('/auth');
}
---

<MainLayout title="BillFlow POS - Reset Password">
  <div class="relative isolate min-h-[100dvh] flex items-center justify-center px-md py-md lg:px-xl lg:py-xl font-body-md text-on-surface antialiased overflow-hidden bg-surface">
    <AuthParticlesBackgroundComponent client:idle />
    <ResetPasswordPageComponent client:load token={token!} />
  </div>
</MainLayout>
