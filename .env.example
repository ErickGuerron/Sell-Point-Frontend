# Firebase Web SDK - Cliente
# No es Firebase Admin SDK
# No colocar service account JSON aqui

# ============================================
# VARIABLES PARA BUILD DEL FRONTEND
# ============================================
# Estas variables se pasan como build args al docker build
# Completar con los valores del proyecto Firebase
# (Firebase Console > Project Settings > Your apps > Web app)

PUBLIC_FIREBASE_API_KEY=tu-api-key-de-firebase
PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
PUBLIC_FIREBASE_APP_ID=tu-app-id

# API URL
# Para desarrollo local: http://localhost:3000
# Para Docker (con nginx proxy): /api
PUBLIC_API_URL=/api

# ============================================
# NOTA IMPORTANTE
# ============================================
# Estas variables se queman en el build de Docker.
# Si necesitás cambiar credenciales de Firebase, hay que recompilar.
#
# Para desarrollo local (sin Docker):
#   npm run dev
#   (usa este .env directamente con Vite)

